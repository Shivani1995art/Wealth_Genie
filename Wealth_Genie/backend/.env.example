# Supabase credentials (obtain from your Supabase Project Settings API tab)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PORT=8000

# --- Milestone 3: Universal Financial Extractor ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key
LLM_MODEL=google/gemini-2.5-flash

# Below this many extracted characters (sampled over the first 3 pages), a
# PDF is classified as scanned and routed through OCR instead of direct text
# extraction.
OCR_TEXT_THRESHOLD_CHARS=50
MAX_OCR_PAGES=15
